# ── BAP Identity ──────────────────────────────────────────────────────────────
# Must match networkParticipant in starter-kit/generic-devkit/config/generic-bap.yaml
# For local dev with the testnet sandbox, use: bap.example.com
BAP_ID=bap.example.com

# URL where the ONIX adapter will POST on_* callbacks.
# Docker stack (recommended): host.docker.internal resolves to your machine from inside Docker.
BAP_URI=http://host.docker.internal:8000/bap/receiver
# Public URL option (ngrok): use this if your BAP URI must be reachable from the internet.
## BAP_URI=https://YOUR_NGROK_URL_HERE

# ── ONIX Adapter ──────────────────────────────────────────────────────────────
# onix-bap container from the starter-kit Docker stack.
ONIX_URL=http://localhost:8081

# ── Protocol Settings ─────────────────────────────────────────────────────────
DOMAIN=beckn.one/testnet
COUNTRY=IND
CITY=std:080
CORE_VERSION=2.0.0

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
CALLBACK_TIMEOUT=15
