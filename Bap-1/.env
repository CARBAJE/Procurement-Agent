# ── BAP Identity ──────────────────────────────────────────────────────────────
# Must match networkParticipant in starter-kit/generic-devkit/config/generic-bap.yaml
BAP_ID=bap.example.com

# URL where the ONIX adapter will POST on_* callbacks (must be reachable from Docker)
BAP_URI=http://host.docker.internal:8000/bap/receiver
## BAP_URI=https://reappoint-levers-urgency.ngrok-free.dev   # use this for ngrok tunnel

# ── ONIX Adapter ──────────────────────────────────────────────────────────────
# onix-bap container (starter-kit). Use mock_onix.py for local dev without Docker.
ONIX_URL=http://localhost:8081

# ── Protocol Settings ─────────────────────────────────────────────────────────
DOMAIN=beckn.one/testnet
COUNTRY=IND
CITY=std:080
CORE_VERSION=2.0.0

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
CALLBACK_TIMEOUT=15
